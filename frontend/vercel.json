{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://assignment-1-ufcs.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://assignment-1-ufcs.onrender.com/uploads/:path*"
    },
    {
      "source": "/((?!api/|uploads/).*)",
      "destination": "/index.html"
    }
  ]
}
